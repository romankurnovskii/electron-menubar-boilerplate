{
  "name": "electron-menubar-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "build/electron/main.js",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "electron:dev": "concurrently \"npm run start\" \"tsc -p electron --skipLibCheck -w\" \"tsc -p electron/preload/tsconfig.json --skipLibCheck -w\" \"wait-on http://localhost:5174 build/electron/main.js build/electron/preload/preload.cjs && electron .\"",
    "electron:build": "npm run build && tsc -p electron --skipLibCheck && tsc -p electron/preload/tsconfig.json --skipLibCheck && electron-builder",
    "electron:dist": "npm run build && tsc -p electron --skipLibCheck && tsc -p electron/preload/tsconfig.json --skipLibCheck && electron-builder --mac --dir"
  },
  "dependencies": {
    "electron-devtools-installer": "^3.2.1",
    "electron-reload": "2.0.0-alpha.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.577.0",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-devtools-installer": "^2.2.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.4.1",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "build": {
    "productName": "productName",
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "universal"
        ]
      },
      "category": "public.app-category.productivity"
    },
    "extends": null,
    "files": [
      "build/**/*",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
